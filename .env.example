# OpenAI-compatible LLM 端点（DeepSeek 默认；测试不需要 key，mock 注入）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# HTTP server
PORT=8000

# Postgres（m05 起需要）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/manus

# Redis（m09 起需要）
REDIS_URL=redis://localhost:6379
